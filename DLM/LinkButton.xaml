<UserControl x:Class="DLM.LinkButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="60"
             >

    <Grid>
        <Button Margin="0,0,60,0"
                Foreground="WhiteSmoke"
                BorderThickness="0"
                Content="main"
                Name="LinkOpenButton"
                >
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="#454545">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border"
                                    Property="Background"
                                    Value="#4F4F4F"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Button Background="#454545"
                Height="60"
                Width="60"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Content="Edit" Foreground="WhiteSmoke"
                Name="EditButton"
                >
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                Background="#FF4C4C4C">
                        <ContentPresenter HorizontalAlignment="Center"
                              VerticalAlignment="Center"/>
                    </Border>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border"
                        Property="Background"
                        Value="#4F4F4F"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

        <Border Background="Red"
                Height="1"
                VerticalAlignment="Bottom"
                Name="isOnlineindicator"
                ></Border>

    </Grid>
</UserControl>